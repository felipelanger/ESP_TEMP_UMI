#include <ESP8266WiFi.h>
#include <ESP8266HTTPClient.h>
#include <ArduinoJson.h>

#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

/* =========================
   WIFI
========================= */

const char* ssid = "NINA_2.4G";
const char* password = "132#Internet";

/* =========================
   API
========================= */

const char* apiUrl =
    "http://ubuntuserver.local:5000/api/oled";

/* =========================
   UPTIME KUMA
========================= */

const char* kumaUp =
    "http://ubuntuserver.local:3001/api/push/jINTbLvK1M?status=up&msg=OLED_OK&ping=1";

const char* kumaDown =
    "http://ubuntuserver.local:3001/api/push/jINTbLvK1M?status=down&msg=API_FAIL&ping=0";

/* =========================
   OLED
========================= */

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

Adafruit_SSD1306 display(
    SCREEN_WIDTH,
    SCREEN_HEIGHT,
    &Wire,
    OLED_RESET
);

/* =========================
   VARIÁVEIS
========================= */

float temp = 0;
float humidity = 0;
float current = 0;
float power = 0;

bool apiConnected = false;

bool blinkState = false;

unsigned long lastBlink = 0;
unsigned long lastUpdate = 0;

/* =========================
   WIFI
========================= */

void connectWifi() {

  Serial.println();
  Serial.println("=========================");
  Serial.println("CONECTANDO WIFI");
  Serial.println("=========================");

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {

    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("WiFi conectado!");

  Serial.print("IP: ");
  Serial.println(WiFi.localIP());
}

/* =========================
   UPTIME KUMA
========================= */

void sendKuma(bool success) {

  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("Kuma ignorado - WiFi OFF");
    return;
  }

  WiFiClient client;
  HTTPClient http;

  const char* url;

  if (success) {
    url = kumaUp;
  } else {
    url = kumaDown;
  }

  Serial.println();
  Serial.println("=========================");
  Serial.println("UPTIME KUMA");
  Serial.println("=========================");

  Serial.print("GET ");
  Serial.println(url);

  http.setTimeout(5000);

  if (!http.begin(client, url)) {

    Serial.println("Falha http.begin() Kuma");
    return;
  }

  int code = http.GET();

  Serial.print("Kuma HTTP Code: ");
  Serial.println(code);

  if (code > 0) {

    String response = http.getString();

    Serial.println("Resposta Kuma:");
    Serial.println(response);

  } else {

    Serial.print("Erro Kuma: ");
    Serial.println(http.errorToString(code));
  }

  http.end();
}

/* =========================
   API
========================= */

bool loadData() {

  if (WiFi.status() != WL_CONNECTED) {

    Serial.println("WiFi desconectado");

    apiConnected = false;

    sendKuma(false);

    return false;
  }

  WiFiClient client;
  HTTPClient http;

  Serial.println();
  Serial.println("=========================");
  Serial.println("TESTE API");
  Serial.println("=========================");

  Serial.print("GET ");
  Serial.println(apiUrl);

  http.setTimeout(10000);

  if (!http.begin(client, apiUrl)) {

    Serial.println("Falha http.begin()");

    apiConnected = false;

    sendKuma(false);

    return false;
  }

  int httpCode = http.GET();

  Serial.print("HTTP Code: ");
  Serial.println(httpCode);

  if (httpCode != HTTP_CODE_OK) {

    Serial.print("Erro HTTP: ");
    Serial.println(http.errorToString(httpCode));

    apiConnected = false;

    sendKuma(false);

    http.end();

    return false;
  }

  String payload = http.getString();

  Serial.println();
  Serial.println("JSON RECEBIDO");
  Serial.println("---------------------------------");
  Serial.println(payload);

  DynamicJsonDocument doc(1024);

  DeserializationError error =
      deserializeJson(doc, payload);

  if (error) {

    Serial.println();
    Serial.println("ERRO JSON");
    Serial.println(error.c_str());

    apiConnected = false;

    sendKuma(false);

    http.end();

    return false;
  }

  temp = doc["temp"] | 0.0;
  humidity = doc["humidity"] | 0.0;
  current = doc["current"] | 0.0;
  power = doc["power"] | 0.0;

  Serial.println();
  Serial.println("VALORES EXTRAIDOS");
  Serial.println("---------------------------------");

  Serial.print("Temp: ");
  Serial.println(temp);

  Serial.print("Humidity: ");
  Serial.println(humidity);

  Serial.print("Current: ");
  Serial.println(current);

  Serial.print("Power: ");
  Serial.println(power);

  apiConnected = true;

  sendKuma(true);

  http.end();

  return true;
}

/* =========================
   OLED
========================= */

void drawDisplay() {

  display.clearDisplay();

  display.setTextColor(SSD1306_WHITE);

  /* -------------------------
     Indicador Status
  ------------------------- */

  if (apiConnected) {

    if (millis() - lastBlink > 500) {

      blinkState = !blinkState;

      lastBlink = millis();
    }

    if (blinkState) {

      display.fillCircle(
          122,
          5,
          3,
          SSD1306_WHITE
      );

    } else {

      display.drawCircle(
          122,
          5,
          3,
          SSD1306_WHITE
      );
    }

  } else {

    display.drawCircle(
        122,
        5,
        3,
        SSD1306_WHITE
    );
  }

  /* -------------------------
     Temperatura
  ------------------------- */

  display.setTextSize(2);

  display.setCursor(0, 0);

  display.print(temp, 1);

  display.write(247);

  display.print("C");

  /* -------------------------
     Umidade
  ------------------------- */

  display.setTextSize(1);

  display.setCursor(0, 22);

  display.print("Hum ");

  display.print(humidity, 0);

  display.print("%");

  /* -------------------------
     Corrente
  ------------------------- */

  display.setCursor(0, 34);

  display.print("Amp ");

  display.print(current, 2);

  display.print("A");

  /* -------------------------
     Potência
  ------------------------- */

  display.setCursor(0, 46);

  display.print("Pwr ");

  display.print(power, 0);

  display.print("W");

  display.display();
}

/* =========================
   SETUP
========================= */

void setup() {

  Serial.begin(115200);

  Serial.println();
  Serial.println("=========================");
  Serial.println("BOOT");
  Serial.println("=========================");

  Wire.begin();

  if (!display.begin(
          SSD1306_SWITCHCAPVCC,
          0x3C)) {

    Serial.println("Falha OLED");

    while (true) {
      delay(1000);
    }
  }

  display.clearDisplay();
  display.display();

  connectWifi();

  loadData();

  drawDisplay();
}

/* =========================
   LOOP
========================= */

void loop() {

  if (millis() - lastUpdate >= 10000) {

    lastUpdate = millis();

    loadData();
  }

  drawDisplay();

  delay(100);
}
